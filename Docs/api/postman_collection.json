{
	"info": {
		"_postman_id": "fibonacci-calculator-api",
		"name": "Fibonacci Calculator API",
		"description": "Collection Postman pour tester l'API REST du Calculateur Fibonacci.\n\n## Configuration\n\nAvant d'utiliser cette collection, assurez-vous que le serveur est démarré :\n\n```bash\n./fibcalc --server --port 8080\n```\n\n## Variables\n\n- `baseUrl` : URL de base du serveur (défaut: http://localhost:8080)",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"variable": [
		{
			"key": "baseUrl",
			"value": "http://localhost:8080",
			"type": "string"
		}
	],
	"item": [
		{
			"name": "Calculation",
			"description": "Endpoints de calcul de Fibonacci",
			"item": [
				{
					"name": "Calculate F(100) with Fast Doubling",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/calculate?n=100&algo=fast",
							"host": ["{{baseUrl}}"],
							"path": ["calculate"],
							"query": [
								{
									"key": "n",
									"value": "100",
									"description": "Index du nombre de Fibonacci"
								},
								{
									"key": "algo",
									"value": "fast",
									"description": "Algorithme à utiliser"
								}
							]
						},
						"description": "Calcule F(100) en utilisant l'algorithme Fast Doubling."
					},
					"response": [
						{
							"name": "Success",
							"originalRequest": {
								"method": "GET",
								"url": {
									"raw": "{{baseUrl}}/calculate?n=100&algo=fast",
									"host": ["{{baseUrl}}"],
									"path": ["calculate"],
									"query": [
										{"key": "n", "value": "100"},
										{"key": "algo", "value": "fast"}
									]
								}
							},
							"status": "OK",
							"code": 200,
							"body": "{\n  \"n\": 100,\n  \"result\": 354224848179261915075,\n  \"duration\": \"125.5µs\",\n  \"algorithm\": \"fast\"\n}"
						}
					]
				},
